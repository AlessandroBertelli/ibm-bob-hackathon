# ============================================
# Group Food Tinder - Frontend .gitignore
# ============================================

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js

# ============================================
# Build Outputs
# ============================================
dist/
dist-ssr/
build/
*.local

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# Keep example file
!.env.example

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Editor & IDE
# ============================================
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains
.idea/
*.iml

# Sublime
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# Operating System
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Linux
*~

# ============================================
# Testing & Coverage
# ============================================
coverage/
.nyc_output/
*.lcov

# ============================================
# Vite
# ============================================
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo
.tsbuildinfo

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
.cache/
.parcel-cache/

# ============================================
# Miscellaneous
# ============================================
# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Storybook
storybook-static/

# Vercel
.vercel
