# ============================================
# Group Food Tinder - Backend .gitignore
# ============================================

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js

# ============================================
# Build Outputs
# ============================================
dist/
build/
*.js.map

# ============================================
# Environment Variables
# ============================================
# Note: backend/.env is tracked with safe defaults for mock mode
# Add your actual credentials to .env.local or override in .env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# Keep example and default files
!.env
!.env.example

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Firebase
# ============================================
firebase-debug.log
firestore-debug.log
ui-debug.log
.firebase/
firebase-debug.*.log

# Firebase service account keys (NEVER commit these!)
*-firebase-adminsdk-*.json
serviceAccountKey.json
firebase-service-account.json

# ============================================
# Editor & IDE
# ============================================
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Sublime
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# Operating System
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Linux
*~

# ============================================
# Testing & Coverage
# ============================================
coverage/
.nyc_output/
*.lcov
test-results/
.jest/

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo
.tsbuildinfo

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
.cache/
tmp/
temp/

# ============================================
# Database
# ============================================
# SQLite
*.sqlite
*.sqlite3
*.db

# MongoDB
data/

# ============================================
# Miscellaneous
# ============================================
# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Compiled binary addons
build/Release

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Vercel
.vercel