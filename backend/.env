# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Service Mode
# Options: 'mock' | 'test' | 'production'
# - mock: No API keys required, uses in-memory mock services
# - test: Uses real APIs for testing (requires API keys)
# - production: Full production mode with all services
SERVICE_MODE=mock

# Firebase Admin SDK (required for 'test' and 'production' modes)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# OpenAI API (required for 'test' and 'production' modes)
OPENAI_API_KEY=

# Email Configuration (required for 'test' and 'production' modes)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@groupfoodtinder.com

# JWT Configuration
JWT_SECRET=dev_jwt_secret_change_in_production_use_long_random_string_here
JWT_EXPIRES_IN=7d

# Magic Link Configuration
MAGIC_LINK_SECRET=dev_magic_link_secret_change_in_production_use_long_random_string_here
MAGIC_LINK_EXPIRES_IN=15m

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug