{
    "name": "group-food-tinder",
    "version": "1.0.0",
    "description": "A collaborative food decision-making application - Root workspace",
    "private": true,
    "scripts": {
        "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
        "dev:mock": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run dev:backend:mock\" \"npm run dev:frontend\"",
        "dev:test": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run dev:backend:test\" \"npm run dev:frontend\"",
        "dev:prod": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run dev:backend:prod\" \"npm run dev:frontend\"",
        "dev:backend": "npm run dev:backend:mock",
        "dev:backend:mock": "cd backend && npm run dev:mock",
        "dev:backend:test": "cd backend && npm run dev:test",
        "dev:backend:prod": "cd backend && npm run dev:prod",
        "dev:frontend": "cd frontend && npm run dev",
        "build": "npm run build:backend && npm run build:frontend",
        "build:backend": "cd backend && npm run build",
        "build:frontend": "cd frontend && npm run build",
        "clean": "npm run clean:backend && npm run clean:frontend",
        "clean:backend": "cd backend && npm run clean",
        "clean:frontend": "cd frontend && rm -rf dist",
        "start": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run start:backend\" \"npm run start:frontend\"",
        "start:backend": "cd backend && npm start",
        "start:frontend": "cd frontend && npm run preview",
        "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
        "typecheck:backend": "cd backend && tsc --noEmit",
        "typecheck:frontend": "cd frontend && tsc -b --noEmit",
        "lint": "npm run lint:backend && npm run lint:frontend",
        "lint:backend": "echo 'Backend linting not configured'",
        "lint:frontend": "cd frontend && npm run lint",
        "check:tailwind": "cd frontend && npx tailwindcss --help > /dev/null && echo 'Tailwind CSS is properly configured' || echo 'Tailwind CSS configuration issue'",
        "check:all": "npm run typecheck && npm run lint && npm run check:tailwind"
    },
    "keywords": [
        "food",
        "tinder",
        "group",
        "restaurant",
        "collaboration"
    ],
    "author": "Group Food Tinder Team",
    "license": "MIT",
    "devDependencies": {
        "concurrently": "^9.1.2"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}