{
    "name": "atavola",
    "version": "2.1.0",
    "description": "atavola — group meal planning via Tinder-style swiping. Single-Vercel-project deploy.",
    "private": true,
    "scripts": {
        "install:all": "npm install && cd frontend && npm install",
        "dev:mock": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm:dev:backend:mock\" \"npm:dev:frontend:mock\"",
        "dev:test": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm:dev:backend:test\" \"npm:dev:frontend\"",
        "dev:prod": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm:dev:backend:prod\" \"npm:dev:frontend\"",
        "dev:backend": "npm run dev:backend:mock",
        "dev:backend:mock": "SERVICE_MODE=mock ts-node-dev --respawn --transpile-only --project tsconfig.json backend/src/dev-server.ts",
        "dev:backend:test": "SERVICE_MODE=test ts-node-dev --respawn --transpile-only --project tsconfig.json backend/src/dev-server.ts",
        "dev:backend:prod": "SERVICE_MODE=production ts-node-dev --respawn --transpile-only --project tsconfig.json backend/src/dev-server.ts",
        "dev:frontend": "cd frontend && npm run dev",
        "dev:frontend:mock": "VITE_SERVICE_MODE=mock cd frontend && npm run dev",
        "build": "cd frontend && npm install && npm run build",
        "typecheck": "npm run typecheck:server && npm run typecheck:frontend",
        "typecheck:server": "tsc --noEmit",
        "typecheck:frontend": "cd frontend && tsc -b --noEmit",
        "lint": "cd frontend && npm run lint"
    },
    "keywords": [
        "atavola",
        "supabase",
        "openrouter",
        "vercel"
    ],
    "author": "atavola",
    "license": "MIT",
    "dependencies": {
        "@supabase/supabase-js": "^2.46.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "@vercel/node": "^5.4.0",
        "concurrently": "^9.1.2",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}
