# =============================================================================
# atavola — Environment template (single Vercel project)
# =============================================================================
# Copy to `.env` and fill in. Never commit the populated `.env`.
# Mock mode (`SERVICE_MODE=mock`) needs no values; entries can stay blank.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (Vercel serverless functions in /api)
# -----------------------------------------------------------------------------

# mock | test | production
SERVICE_MODE=

# Supabase (server-side). Service-role key bypasses RLS — server only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter — LLM with rotation through OPENROUTER_MODELS in order on
# any retryable failure (429 / 5xx / timeout / empty response).
# Pick free model slugs from https://openrouter.ai/models?max_price=0.
OPENROUTER_API_KEY=
OPENROUTER_MODELS=

# Image generation — comma-separated providers tried in order.
# Available: pollinations, huggingface, cloudflare.
IMAGE_PROVIDERS=

# Hugging Face Inference (free with a token from
# https://huggingface.co/settings/tokens).
HUGGINGFACE_API_TOKEN=

# Cloudflare Workers AI (free tier — see DEPLOYMENT_GUIDE.md).
# Token only needs the "Workers AI" permission.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Local dev only — overrides the default frontend origin for CORS in
# the dev-server. Vercel functions in production share the origin so
# this is unused there.
FRONTEND_URL=

# -----------------------------------------------------------------------------
# Weekly stats email (Vercel Cron → /api/_cron/weekly-stats)
# -----------------------------------------------------------------------------
# Resend API key. The Vercel cron function uses the Resend HTTP API directly
# (separate from the Supabase Auth → SMTP route used for magic-links, which
# can stay configured the same way as before).
RESEND_API_KEY=

# Sender for transactional emails sent directly via Resend (currently the
# weekly stats digest). Format: "name <address>" or just "address". The
# domain part must be verified in Resend or delivery will bounce.
# Example: "atavola <no-reply@atavola.ch>"
EMAIL_FROM=

# Vercel signs cron requests with `Authorization: Bearer ${CRON_SECRET}`.
# Set this in the Vercel dashboard; the same value goes in the env vars
# block AND in the project's Cron Job settings.
CRON_SECRET=

# Comma-separated recipient list, e.g. "alex@example.com,marco@example.com".
# Empty = the cron runs but skips sending (useful in staging).
STATS_EMAIL_RECIPIENTS=

# Schedule lives in vercel.json (`crons` block) — change it there, then
# redeploy. Default: every Monday 09:00 UTC ("0 9 * * 1").

# -----------------------------------------------------------------------------
# Frontend (Vite, browser-side)
# -----------------------------------------------------------------------------

# Anon key is safe to expose; RLS protects the data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional. Defaults to the same origin (`/api`) which is what you want
# in production. Override for local dev when the dev-server runs on a
# different port than Vite (defaults handle the standard 3000 + 5173 setup).
VITE_API_URL=

# =============================================================================
# Setup checklist
# =============================================================================
# 1. Apply supabase/migrations/0001_init.sql in the Supabase SQL editor.
# 2. Auth → URL Configuration: Site URL + ${SITE_URL}/auth/verify redirect.
# 3. Auth → Email Templates: review the magic-link copy. Default English is fine.
# 4. Auth → SMTP Settings: wire up Resend (or another provider).
# 5. For dev with no keys, leave SERVICE_MODE=mock — everything boots blank.
# =============================================================================
