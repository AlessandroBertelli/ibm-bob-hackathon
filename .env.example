# =============================================================================
# GROUP FOOD TINDER - Environment Configuration
# =============================================================================
# This file contains all environment variables for both backend and frontend.
# Copy this file to .env and fill in your actual values.
#
# IMPORTANT: Never commit the actual .env file to version control!
# =============================================================================

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Service Mode
# Options: 'mock' | 'test' | 'production'
# - mock: No API keys required, uses in-memory mock services
# - test: Uses real APIs for testing (requires API keys)
# - production: Full production mode with all services
SERVICE_MODE=mock

# Firebase Admin SDK (Backend)
# Get these from Firebase Console > Project Settings > Service Accounts
# Generate new private key and use the values from the downloaded JSON
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com

# OpenAI API
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Email Configuration (for magic link authentication)
# For Gmail: Use App Password (not your regular password)
# Enable 2FA and generate app password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@groupfoodtinder.com

# JWT Configuration
# Generate secure random strings for production
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_change_in_production_use_long_random_string
JWT_EXPIRES_IN=7d

# Magic Link Configuration
MAGIC_LINK_SECRET=your_magic_link_secret_key_change_in_production_use_long_random_string
MAGIC_LINK_EXPIRES_IN=15m

# Database Configuration (if using a database later)
# DATABASE_URL=postgresql://user:password@localhost:5432/groupfoodtinder

# Redis Configuration (if using Redis for sessions/caching)
# REDIS_URL=redis://localhost:6379

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# API Configuration
VITE_API_URL=http://localhost:3000

# Firebase Configuration (Frontend)
# Get these values from your Firebase project settings
# https://console.firebase.google.com/
# Note: These are different from the backend Firebase Admin SDK credentials
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: Firebase Measurement ID for Analytics
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file to .env in the root directory
# 2. Fill in your actual values for each variable
# 3. For development with mock services, you can leave SERVICE_MODE=mock
#    and skip the API keys (Firebase, OpenAI, SMTP)
# 4. For production, set SERVICE_MODE=production and provide all credentials
# 5. Make sure .env is in your .gitignore file
# =============================================================================